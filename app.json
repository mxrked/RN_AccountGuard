{
  "expo": {
    "name": "RN_AccountGuard",
    "slug": "RN_AccountGuard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imgs/pre-build-icons/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/imgs/pre-build-icons/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pahkah.RN_AccountGuard"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/imgs/pre-build-icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/imgs/pre-build-icons/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3dbdb7ec-4021-4797-a256-5cfdb0e0576a"
      }
    }
  }
}
